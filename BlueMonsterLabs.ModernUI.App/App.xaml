<Application x:Class="BlueMonsterLabs.ModernUI.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--- ModernUI controls -->
                <ResourceDictionary Source="/BlueMonsterLabs.ModernUI;component/Assets/ModernUI.xaml" />
                <!-- Your special theme -->
                <ResourceDictionary Source="/Assets/ModernUI.Smoke.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
